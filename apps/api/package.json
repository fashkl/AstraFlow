{
  "name": "@livecoding/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.json src/main.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest --config jest.config.cjs --runInBand",
    "typecheck": "tsc --noEmit -p tsconfig.spec.json"
  },
  "dependencies": {
    "@livecoding/shared": "workspace:*",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "opossum": "^8.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.6.0",
    "@types/opossum": "^8.1.8",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "ts-jest": "^29.4.5",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2"
  }
}
